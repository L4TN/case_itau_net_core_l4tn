{
  "ConnectionStrings": {
    "DefaultConnection": "Server=#{DB_SERVER_PRD}#;Database=CaseItauDb;User Id=#{DB_USER_PRD}#;Password=#{DB_PASSWORD_PRD}#;TrustServerCertificate=true;Encrypt=true;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.EntityFrameworkCore": "Error",
        "System": "Error",
        "CaseItau": "Information"
      }
    }
  },
  "Jwt": {
    "Key": "#{JWT_SECRET_KEY_PRD}#",
    "ExpirationInMinutes": 30
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "#{REDIS_CONNECTION_PRD}#",
    "InstanceName": "CaseItau_PRD_",
    "ExpirationInSeconds": 300
  },
  "AWS": {
    "CloudWatch": {
      "Enabled": true,
      "LogGroup": "/caseitau/api/prd",
      "Region": "#{AWS_REGION}#"
    }
  }
}
